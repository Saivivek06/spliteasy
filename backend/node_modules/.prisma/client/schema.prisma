generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  passwordHash String
  displayName  String
  avatarColor  String   @default("#6366f1")
  createdAt    DateTime @default(now())

  groupMembers    GroupMember[]
  paidExpenses    Expense[]      @relation("PaidBy")
  expenseSplits   ExpenseSplit[]
  sentMessages    Message[]
  settlementsFrom Settlement[]   @relation("SettlementFrom")
  settlementsTo   Settlement[]   @relation("SettlementTo")
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())
  createdById Int

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id       Int      @id @default(autoincrement())
  groupId  Int
  userId   Int
  role     String   @default("member") // admin | member
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  groupId     Int
  description String
  amount      Float
  currency    String   @default("INR")
  splitType   String // equal | unequal | percentage | share
  paidById    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group    Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy   User           @relation("PaidBy", fields: [paidById], references: [id])
  splits   ExpenseSplit[]
  messages Message[]
}

model ExpenseSplit {
  id         Int     @id @default(autoincrement())
  expenseId  Int
  userId     Int
  amount     Float
  percentage Float?
  shares     Float?
  settled    Boolean @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id        Int      @id @default(autoincrement())
  groupId   Int
  fromId    Int
  toId      Int
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  from  User  @relation("SettlementFrom", fields: [fromId], references: [id])
  to    User  @relation("SettlementTo", fields: [toId], references: [id])
}

model Message {
  id        Int      @id @default(autoincrement())
  expenseId Int
  userId    Int
  content   String
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
